    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mayaross/auth": "^1.0.0"
  },
  "bundleDependencies": [
