  "homepage": "https://github.com/mayarid/mayar-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayarid/mayar-cli.git"
  },
  "bugs": {
    "url": "https://github.com/mayarid/mayar-cli/issues"
  },
  "files": [
    "bin",
