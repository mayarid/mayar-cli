{
  "name": "mayar",
  "version": "1.0.1",
  "description": "Zero-dependency Node.js CLI for the Mayar API (production endpoint).",
  "bin": {
    "mayar": "bin/mayar.js"
  },
  "main": "src/cli.js",
  "scripts": {
